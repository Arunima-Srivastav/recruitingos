# Supabase (required)
# Create a project at https://supabase.com, then run supabase/schema.sql in the SQL editor.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Ollama Cloud (optional — heuristic fallback if unset)
# Create an API key at https://ollama.com → Settings → Keys
OLLAMA_API_KEY=your-ollama-api-key
OLLAMA_BASE_URL=https://ollama.com
# Cost-effective default: ministral-3:3b (smallest model on Ollama Cloud API)
OLLAMA_MODEL=ministral-3:3b

# Google OAuth (required for Gmail import)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Enable Gmail API. Redirect URI must match exactly.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
NEXT_PUBLIC_APP_URL=http://localhost:3000
