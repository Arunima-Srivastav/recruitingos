# Supabase (required)
# Create a project at https://supabase.com, then run supabase/schema.sql in the SQL editor.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Ollama Cloud (required for AI message extraction)
# Create an API key at https://ollama.com → Settings → Keys
# Pick a cloud model from https://ollama.com/search (filter: Cloud)
OLLAMA_API_KEY=your-ollama-api-key
OLLAMA_BASE_URL=https://ollama.com
# Cost-effective default: ministral-3:3b (smallest model on Ollama Cloud API)
# Run: curl https://ollama.com/api/tags -H "Authorization: Bearer $OLLAMA_API_KEY" to list yours
OLLAMA_MODEL=ministral-3:3b

# Future phases
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# NEXT_PUBLIC_APP_URL=http://localhost:3000
