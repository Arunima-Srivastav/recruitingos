# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment / secrets (never commit)
.env.local
.env.development.local
.env.test.local
.env.production.local
.env
.env.*
!.env.example

# Cursor / agent docs (optional local notes)
AGENTS.md
CLAUDE.md

# Project docs — README.md is tracked (not ignored)

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
